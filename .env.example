# Copy to `.env` and fill in values (never commit `.env`).
# Docker Compose reads `.env` from the project root for variable substitution.

# --- OpenAI (embeddings + LLM per Stack.md / PHASE_1_DATA.md) ---
OPENAI_API_KEY=

# --- Qdrant ---
# ВАЖНО: uvicorn на хосте (Windows/Mac/Linux) → всегда localhost и проброс порта:
QDRANT_URL=http://127.0.0.1:6333
#
# Только если сам backend запущен ВНУТРИ Docker Compose рядом с сервисом qdrant:
# QDRANT_URL=http://qdrant:6333
#
# Если Qdrant требует api-key по HTTP (редко локально), добавьте:
# GARBAGE_QDRANT_HTTP_API_KEY=1
# Optional; must match QDRANT__SERVICE__API_KEY in docker-compose when set.
QDRANT_API_KEY=

# Host port mappings (optional); defaults match docker-compose.yml
# QDRANT_HTTP_PORT=6333
# QDRANT_GRPC_PORT=6334

# --- Backend (FastAPI, optional env_prefix GARBAGE_) ---
# GARBAGE_ZIP_DB_PATH=
# GARBAGE_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8080
# GARBAGE_LOG_LEVEL=INFO
#
# Admin RAG API (/api/v1/admin/*): заголовок X-Admin-Token или Admin-Token
# GARBAGE_ADMIN_API_TOKEN=
#
# Промпты Vision + вердикта для POST /analyze: вкладка «Промпты ИИ» на /admin
# (файл data/ai_prompts.json, том ./data в Docker).
#
# Индекс → district_id: формы analyze и admin/upload используют zip_codes.db (поле zip_code).
